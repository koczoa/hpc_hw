# LSBATCH: User input
#!/bin/bash
#BSUB -J cupy_nsys
#BSUB -q c02613
#BSUB -gpu "num=1:mode=exclusive_process"
#BSUB -W 00:30
#BSUB -n 4
#BSUB -R "span[hosts=1]"
#BSUB -R "rusage[mem=4GB]"
#BSUB -o nsys_%J.out
#BSUB -e nsys_%J.err

source /dtu/projects/02613_2025/conda/conda_init.sh
conda activate 02613_2026

echo "=== 1. Profiling ORIGINAL CuPy (with per-iteration sync) ===" >&2
nsys profile -o cupy_orig_trace --force-overwrite=true \
    --trace=cuda,nvtx,osrt --sample=none \
    python simulate_cupy.py 3 > /dev/null

echo "=== 2. Profiling FIXED CuPy (sync every 100 iters) ===" >&2
nsys profile -o cupy_fixed_trace --force-overwrite=true \
    --trace=cuda,nvtx,osrt --sample=none \
    python simulate_cupy_fixed.py 3 > /dev/null

echo "=== 3. Timing FIXED CuPy on N=20 ===" >&2
python simulate_cupy_fixed.py 20 > /dev/null

echo "=== 4. nsys summary: ORIGINAL ===" >&2
nsys stats --report cuda_api_sum,cuda_gpu_kern_sum,cuda_gpu_mem_time_sum \
    cupy_orig_trace.nsys-rep 2>&1 | head -100

echo "=== 5. nsys summary: FIXED ===" >&2
nsys stats --report cuda_api_sum,cuda_gpu_kern_sum,cuda_gpu_mem_time_sum \
    cupy_fixed_trace.nsys-rep 2>&1 | head -100
